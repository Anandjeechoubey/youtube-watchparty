{
  "manifest_version": 3,
  "name": "PAWP connect",
  "version": "1.0.0",
  "description": "Watch YouTube together in perfect sync with friends — shared play, pause, seek, speed, and chat. Host a watch party in one click.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "PAWP connect",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "shared/config.js",
        "shared/messages.js",
        "shared/storage.js",
        "content/sync.js",
        "content/player.js",
        "content/overlay.js",
        "content/content.js"
      ],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
